# Copy to loadtest/.env and fill in real values.
# loadtest/.env is gitignored (the repo-level .env entry covers it too).

ENV=preprod

LOAD_USERNAME=segobc2@ripplr.in
LOAD_PASSWORD=Ripplr@123

# Geo headers — match what the browser sends. Defaults in env.js will be used if blank.
USER_IP=103.242.225.82
USER_LATITUDE=28.494101316774074
USER_LONGITUDE=77.09228445136326

# k6 built-in web dashboard (http://127.0.0.1:5665 while a run is in progress).
# EXPORT writes a self-contained snapshot you can open after the run finishes.
K6_WEB_DASHBOARD=true
K6_WEB_DASHBOARD_EXPORT=loadtest/reports/k6-dashboard.html
